# 可选：放在仓库根目录，供 docker compose 读取（复制为 .env）
# API_PORT=8000
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# DEBUG=false
# CORS_ORIGINS=https://你的前端域名,http://localhost:5173
# ROOT_PATH=
# 默认 compose 已写 postgres/redis；覆盖示例：
# DATABASE_URL=postgresql+asyncpg://uniai:uniai@postgres:5432/uniai
# REDIS_URL=redis://redis:6379/0
