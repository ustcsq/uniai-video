# 复制为 backend/.env 后按需修改（本地 conda / 直接 uvicorn 时使用）

# DEBUG=true
# LOG_LEVEL=INFO

# 逗号分隔的前端来源，上云改为 https 域名
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 反代子路径时 OpenAPI 用，一般可留空
# ROOT_PATH=

# 默认（可不写）：sqlite+aiosqlite:///./data/dev.db
# 本地 Docker Postgres：postgresql+asyncpg://uniai:uniai@127.0.0.1:5432/uniai
# DATABASE_URL=postgresql+asyncpg://uniai:uniai@127.0.0.1:5432/uniai

# 不配则 health 里 redis 为 skipped
# REDIS_URL=redis://127.0.0.1:6379/0

# JWT（生产务必设置长随机串）
# JWT_SECRET=...

# 本地/单测：固定验证码（切勿上生产）
# AUTH_DEV_FIXED_CODE=123456
# 调试时在发码接口 JSON 中返回 debug_code（切勿上生产）
# SMS_DEBUG_RETURN_CODE=true
